# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Node / Vite frontend ────────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
.vite/
*.local
*.tsbuildinfo

# ─── Rust / Cargo / Tauri backend ────────────────────────────────────────────
# Cargo build artifacts — large; never commit.
target/
src-tauri/target/
# Tauri 2 auto-generated capability schemas (per build).
src-tauri/gen/
# Cargo backup files.
**/*.rs.bk
**/Cargo.lock.bak
# Don't ignore Cargo.lock itself — this is an application, not a library,
# and committing it keeps builds reproducible.

# ─── Bundle / installer outputs ──────────────────────────────────────────────
# These live under target/ already, but explicit just in case someone moves them.
*.msi
*.nsis-output.exe
*-setup.exe
src-tauri/target/release/bundle/

# ─── Runtime / local app data ────────────────────────────────────────────────
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
agentlane.project.json   # exported personal project files

# ─── Secrets / env ───────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example

# ─── Editor / IDE ────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.swn
*~

# ─── OS junk ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ─── Tool histories / caches ─────────────────────────────────────────────────
.specstory/
.cache/

# ─── Project-specific ─────────────────────────────────────────────────────────
# Mobile icon sets (we ship Windows only; Tauri regenerates if needed).
src-tauri/icons/ios/
src-tauri/icons/android/
